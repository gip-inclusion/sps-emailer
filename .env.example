# === Brevo (envoi) ===
BREVO_API_KEY=                                        # requis (envoi) — clé API Brevo transactionnel
BREVO_SENDER=expediteur-valide@example.org            # requis (envoi) — expéditeur, doit être VALIDÉ dans Brevo
TEST_RECIPIENTS=test1@example.org,test2@example.org   # requis pour `send --test` — liste séparée par des virgules

# === Tunnel SOCKS d'egress (IP fixe whitelistée Brevo) — coordonnées réelles, non versionnées ===
SPS_TUNNEL_HOST=                                      # requis (envoi) — hôte/IP de la box tunnel
SPS_TUNNEL_USER=tunnel                                # requis (envoi) — user SSH du tunnel
# BREVO_PROXY=socks5h://127.0.0.1:1080                # optionnel — sinon passer --via ; le tunnel doit être ouvert
